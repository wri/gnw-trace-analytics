# Zeno API — serves the superuser-gated trace endpoints (/api/traces*) and
# user endpoints (/api/auth/me, /api/admin/users). No secrets live in this app:
# every request is authenticated with the signed-in user's own Resource Watch
# bearer token, and the API enforces superuser access server-side.
# NOTE: api.staging.… resolves; staging.api.… does NOT — don't swap them.
NEXT_PUBLIC_API_HOST=https://api.staging.globalnaturewatch.org

# Resource Watch auth host (login/logout redirects). Defaults to production.
NEXT_PUBLIC_RW_API_URL=https://api.resourcewatch.org
